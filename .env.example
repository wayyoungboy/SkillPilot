# PowerSkills 环境变量配置

# ===========================================
# SeekDB 配置 (唯一存储基建)
# ===========================================
SEEKDB_URL=seekdb://localhost:6432
SEEKDB_VECTOR_DIMENSION=1536
SEEKDB_INDEX_TYPE=hnsw
SEEKDB_HNSW_M=16
SEEKDB_HNSW_EF_CONSTRUCTION=200

# ===========================================
# JWT 配置
# ===========================================
# 生产环境请修改为安全的随机字符串
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# API 配置
# ===========================================
API_V1_PREFIX=/api/v1
PROJECT_NAME=PowerSkills
DEBUG=false

# ===========================================
# 限流配置
# ===========================================
RATE_LIMIT_PER_MINUTE=100

# ===========================================
# AI Provider 配置
# ===========================================
# OpenAI API Key (用于 Embedding 和 LLM)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic API Key (可选，用于 LLM)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Embedding Provider: mock, openai, local
# - mock: 开发/测试模式，无需 API Key，生成随机向量
# - openai: 使用 OpenAI text-embedding-3-small
# - local: 使用本地 sentence-transformers 模型
EMBEDDING_PROVIDER=mock

# LLM Provider: mock, openai, anthropic
# - mock: 开发/测试模式，无需 API Key，返回基础分析结果
# - openai: 使用 GPT-4o-mini
# - anthropic: 使用 Claude 3 Haiku
LLM_PROVIDER=mock

# ===========================================
# Platform API 配置
# ===========================================
# Coze API Base URL
COZE_API_BASE=https://api.coze.com

# Dify API Key
DIFY_API_KEY=your-dify-api-key
DIFY_API_BASE=https://api.dify.ai/v1

# LangChain/LangServe Endpoint (可选)
LANGCHAIN_ENDPOINT_URL=
